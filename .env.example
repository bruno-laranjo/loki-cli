# loki-cli environment variables
#
# Every variable below overrides the corresponding setting from the active
# config profile at runtime. Precedence: CLI flags > env vars > profile file.
# Copy to `.env` and source it, or export the vars in your shell.

# Loki endpoint (required if no profile is configured).
LOKI_URL=https://loki.example.com

# Multi-tenant tenant ID; sent as X-Scope-OrgID.
# LOKI_ORG_ID=my-tenant

# Disable TLS certificate verification (INSECURE). Accepts 1/true/yes/on.
# LOKI_TLS_SKIP_VERIFY=false

# --- Authentication (pick ONE) ------------------------------------------

# Bearer token / API key (takes precedence over basic auth if both are set).
# LOKI_TOKEN=eyJhbGciOi...

# HTTP basic auth.
# LOKI_USERNAME=alice
# LOKI_PASSWORD=super-secret

# --- Profile selection --------------------------------------------------

# Which named profile to use (same as `--profile NAME`).
# LOKI_PROFILE=default
